# PathNova AI - Environment Variables
# Copy this file to .env and fill in your values.

# ── Required ───────────────────────────────────────────────
# Get your FREE Groq API key at https://console.groq.com
# No credit card needed - sign up with Google in 30 seconds
GROQ_API_KEY=gsk_your_key_here

# ── Optional ───────────────────────────────────────────────
# GitHub personal access token for higher rate limits on GitHub API
# Generate at https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# ── Server ─────────────────────────────────────────────────
ENVIRONMENT=development   # development | production

# ── CORS (comma-separated origins) ────────────────────────
# Add your production frontend URL here
# CORS_ORIGINS=["http://localhost:5173","https://your-app.vercel.app"]

# ── Limits ─────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
CACHE_TTL=3600            # session TTL in seconds (1 hour)
